{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":rebaseStalePrs",
    ":prHourlyLimitNone",
    ":dependencyDashboard"
  ],
  "rangeStrategy": "pin",
  "packageRules": [
    {
      "matchCategories": [
        "python"
      ],
      "enabled": true
    },
    {
      "matchUpdateTypes": ["minor", "patch"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true
    }
  ],
  "github-actions": {
    "enabled": true
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/custom_components/openwrt/helpers/mqtt_presence.py/"],
      "matchStrings": ["# renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?)\\s+REPO_URL = \"https://raw.githubusercontent.com/[^/]+/[^/]+/(?<currentValue>[a-f0-9]+)\""]
    }
  ]
}
